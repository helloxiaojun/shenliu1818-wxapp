/* 规格详情 */
.config-group {
  margin-bottom: 24rpx;
}

.config-group:last-child {
  margin-bottom: 0;
}

.config-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #555555;
  display: block;
  margin-bottom: 12rpx;
}

.config-scroll {
  display: flex;
  white-space: nowrap;
  width: 100%;
  height: 60rpx;
  /* margin-left: -20rpx; */
  /* width: calc(100% + 40rpx); */
  /* padding-left: 20rpx; */
  box-sizing: border-box;
  /* background-color: red; */
}

.config-card {
  width: 210rpx;
  /* height: 60rpx; */
  height: 60rpx;
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  background: #f9f9f9;
  border: 1rpx solid #EEEEEE;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  position: relative;
  box-sizing: border-box;
  transition: all 0.2s;
  /* background-color:aqua; */
}

.config-card.active {
  background: #f0f7ff;
  border-color: #0052d9;
  color: #0052d9;
}

.c-check {
  position: absolute;
  top: 0;
  right: 0;
  background: #0052d9;
  color: #FFFFFF;
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-bottom-left-radius: 8rpx;
  border-top-right-radius: 8rpx;
}

.config-card.readonly {
  background: #F8F9FA;
  border-color: #e0e0e0;
  color: #333333;
}

.c-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #333333;
  white-space: normal;
  line-height: 1;
  display: -webkit-box;
  -webkit-box-orient: 2;
  -webkit-line-clamp: 2;
  overflow: hidden;
  /* background-color: aqua; */
}

.config-card.active .c-name {
  color: #0052d9;
  font-weight: bold;
}

.c-price {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
  overflow: hidden;
}

.config-card.active .c-price {
  color: #0052d9;
}