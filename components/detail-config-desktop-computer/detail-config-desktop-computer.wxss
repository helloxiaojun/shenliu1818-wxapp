/* 容器与间距 */
.config-group {
  margin-bottom: 32rpx;
}

.config-group:last-child {
  margin-bottom: 0;
}

/* 标签样式：增强层级感 */
.config-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* 滚动区域：隐藏滚动条 */
.config-scroll {
  display: flex;
  white-space: nowrap;
  width: 100%;
  height: 84rpx; /* 增加高度以容纳阴影 */
  box-sizing: border-box;
}

.config-scroll::-webkit-scrollbar {
  display: none; /* 隐藏滚动条 */
}

/* 配置卡片基础样式 */
.config-card {
  width: 240rpx;
  height: 72rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
  position: relative;
  box-sizing: border-box;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  padding: 0 16rpx;
}

/* 选中状态：商务蓝 */
.config-card.active {
  background: #f0f7ff;
  border-color: #0052d9;
  box-shadow: 0 4rpx 12rpx rgba(0, 82, 217, 0.08);
}

/* 选中状态的角标或装饰 (如果 wxml 中有 c-check) */
.c-check {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  background: #0052d9;
  color: #FFFFFF;
  font-size: 14rpx;
  padding: 2rpx 8rpx;
  border-bottom-left-radius: 10rpx;
  border-top-right-radius: 10rpx;
  font-weight: bold;
}

/* 只读或禁用状态 */
.config-card.readonly {
  background: #f5f5f5;
  border-color: #eeeeee;
  opacity: 0.6;
}

/* 文字样式 */
.c-name {
  font-size: 24rpx;
  font-weight: 400;
  color: #555555;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.2;
}

/* 选中后的文字加粗 */
.config-card.active .c-name {
  color: #0052d9;
  font-weight: 600;
}

/* 技术描述文字 (备用) */
.c-price {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
  display: none; /* 如果需要双行显示，请将 card 高度调大并取消此隐藏 */
}

/* 交互态 */
.config-card:active {
  transform: scale(0.97);
  opacity: 0.8;
}