page {
  height: 100vh;
  background-color: #f5f5f5; 
}

.main-container {
  display: flex;
  height: 100%;
}

/* 左侧导航 */
.side-nav {
  width: 180rpx;
  flex-shrink: 0;
  background-color: #ffffff;
  height: 100%;
  border-right: 1rpx solid #eeeeee;
  overflow: hidden;
}

.nav-item {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
  position: relative;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.nav-item text {
  white-space: nowrap; /* 不换行 */
  overflow: hidden; /* 超出隐藏 */
  text-overflow: ellipsis; /* 变成省略号 */
  text-align: center;
}

.nav-item.active {
  color: #0052d9; 
  font-weight: bold;
  background-color: #f0f7ff;
}

.nav-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  width: 8rpx;
  height: 40rpx;
  background-color: #0052d9;
  border-radius: 0 4rpx 4rpx 0;
}

/* 右侧内容 */
.content-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.filter-bar {
  height: 80rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  font-size: 26rpx;
  color: #333;
  display: flex;
  align-items: center;
}

.filter-item.active {
  color: #0052d9;
}

.sort-icon {
  margin-left: 8rpx;
  font-size: 24rpx;
}

.total-count {
  font-size: 22rpx;
  color: #999;
}

.product-scroll {
  flex: 1;
  height: 0; /* 配合 flex: 1 让 scroll-view 撑满剩余高度，确保垂直滚动正常 */
  width: 100%;
}

/* 产品卡片样式 */
.list-card {
  display: flex;
  background-color: #ffffff;
  margin: 20rpx 24rpx 0;
  padding: 20rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.card-img {
  width: 180rpx;
  height: 180rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0; /* 防止文字溢出失效 */
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  
  /* 单行截断 */
  /* white-space: nowrap; */

  /* 两行截断 */
  display: -webkit-box;/* 将对象作为弹性伸缩盒子模型显示 */
  -webkit-box-orient: vertical;/* 设置或检索伸缩盒对象的子元素的排列方式为垂直 */
  -webkit-line-clamp: 2;/* 限制在一个块元素显示的文本的行数（这里设为2行） */
  
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 引用原有的 spec 样式 [cite: 53, 54, 55] */
.prod-spec-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin: 10rpx 0;
}

.spec-item {
  display: flex;
  font-size: 20rpx;
  line-height: 1.2;
}

.spec-label {
  color: #999999;
  width: 80rpx;
  flex-shrink: 0;
}

.spec-val {
  flex: 1;
  min-width: 0;
  color: #555555;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-bottom {
  display: flex;
  justify-content: flex-end;
}

.price-group {
  color: #e34d59;
  font-weight: bold;
}

.p-symbol { font-size: 22rpx; }
.p-num { font-size: 32rpx; }
.p-unit { font-size: 20rpx; color: #999; font-weight: normal; }

.list-footer {
  text-align: center;
  font-size: 22rpx;
  color: #ccc;
  padding: 40rpx 0;
}