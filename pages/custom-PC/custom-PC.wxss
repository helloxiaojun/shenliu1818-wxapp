/**index.wxss**/
page {
  /* height: 100vh; */
  height: 100%;
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
  background-color: #f5f5f5;
}


.container {
  padding: 20rpx;
  /* min-height: 100vh; */
  /* background-color: #667eea; */
}

.header {
  text-align: center;
  /* margin-bottom: 40rpx; */
  /* background-color: #764ba2; */
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #666;
}

/* 组件区域样式 */
.component-section {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-top: 25rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
  /* background-color: #3498db; */
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  /* margin-bottom: 25rpx; */
  position: relative;
  /* background-color: #856404; */
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  /* background-color: #667eea; */
}

/* 重新选择区域样式 */
.reselect-area {
  position: absolute;
  right: 0;
  top: 0;
}

.reselect-btn {
  background-color: transparent;
  color: #3498db;
  border: 1rpx solid #3498db;
  border-radius: 15rpx;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

/* 禁用提示样式 */
.disabled-tip {
  background-color: #f8f9fa;
  border: 1rpx solid #e9ecef;
  border-radius: 8rpx;
  padding: 20rpx 0rpx;
  text-align: center;
  margin-top: 25rpx;
  /* background-color: #667eea; */
}

.disabled-tip .tip-text {
  font-size: 24rpx;
  color: #6c757d;
  font-style: italic;
  /* background-color: #764ba2;
   */
}

/* 已选显示样式 */
.selected-display {
  background: linear-gradient(135deg, #f8fafc 0%, #e3f2fd 100%);
  border-radius: 12rpx;
  padding: 25rpx;
  border: 2rpx solid #3498db;
  margin-top: 25rpx;
}

.selected-info {
  flex: 1;
}

.selected-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
  /* margin-bottom: 8rpx; */
}

/* 用于不选择硬盘、显卡、显示器后的提示*/
.selected-name.not-needed {
  color: #7f8c8d;
  font-style: italic;
  /* background-color: #e74c3c; */
}

.selected-description {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  /* background-color: #856404; */
}

.selected-tags {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  /* gap: 8rpx; */
}

.tag {
  background-color: #e3f2fd;
  color: #1976d2;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
}

/* 组件列表样式 */
.component-list {
  /* display: flex;
  flex-direction: column;
  gap: 20rpx; */
}

.component-item {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 25rpx;
  transition: all 0.3s ease;
  margin-top: 25rpx;
  /* cursor: pointer; */
}

.component-item.available:active {
  transform: scale(0.98);
}

/* .component-item.selected {
  border-color: #3498db;
  background-color: #f8fafc;
  box-shadow: 0 4rpx 12rpx rgba(52, 152, 219, 0.2);
} */

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.item-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.item-description {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.item-tags {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  /* gap: 8rpx; */
}

/* 不需要选项样式 */
.not-needed-option {
  margin-top: 25rpx;
  border: 2rpx dashed #bdc3c7;
  border-radius: 12rpx;
  padding: 25rpx;
  text-align: center;
  /* cursor: pointer; */
  transition: all 0.3s ease;
  background-color: #f8f9fa;
}

.not-needed-option:active {
  background-color: #e9ecef;
  transform: scale(0.98);
}

.not-needed-text {
  display: block;
  font-size: 26rpx;
  color: #7f8c8d;
  margin-bottom: 8rpx;
}

.not-needed-desc {
  display: block;
  font-size: 22rpx;
  color: #bdc3c7;
}

/* 获取报价区域样式 */
.quote-section {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  margin: 25rpx 0 0;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
}

.required-tip {
  text-align: center;
  margin-bottom: 20rpx;
  padding: 15rpx;
  background-color: #fff3cd;
  border: 1rpx solid #ffeaa7;
  border-radius: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #856404;
}

.quote-button {
  width: 100%;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.quote-button.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.quote-button.disabled {
  background-color: #bdc3c7;
  color: #7f8c8d;
}

/* 加载和结果样式 */
.loading {
  text-align: center;
  padding: 30rpx;
  color: #3498db;
  font-size: 26rpx;
}

.rent-result {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-top: 25rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
}

.result-header {
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.result-content {
  display: flex;
  flex-direction: column;
}

.rent-amount {
  font-size: 48rpx;
  font-weight: bold;
  color: #e74c3c;
  text-align: center;
  margin-bottom: 20rpx;
}

.rent-note {
  font-size: 24rpx;
  color: #7f8c8d;
  text-align: center;
  margin-bottom: 25rpx;
}

.result-details {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.detail-item {
  display: block;
  font-size: 24rpx;
  color: #555;
  padding: 8rpx 0;
}