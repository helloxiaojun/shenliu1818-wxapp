# 微信小程序项目 .gitignore 文件

# 依赖目录
node_modules/

# 构建产物
dist/
build/

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 运行时数据
*.pid
*.seed
*.pid.lock

# 操作系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE 和编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 微信开发者工具生成的文件
# 注意：这个文件包含项目配置，团队协作时可能需要保留
# project.config.json
unpackage/           # HBuilderX 生成目录（如果使用）

# 小程序特定文件
# 临时文件
__test__/
__pycache__/

# 敏感信息
*.env
.env.local
.env.development
.env.production

# 源代码映射
*.map

# 包管理器锁文件（根据项目需要选择是否忽略）
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# 测试覆盖率
coverage/
.nyc_output/

# 缓存文件
.cache/

# 其他
.sass-cache/
*.css.map
*.sass.map
*.scss.map