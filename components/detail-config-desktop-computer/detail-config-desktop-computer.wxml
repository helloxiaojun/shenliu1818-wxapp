<!-- 台式电脑配置详情 -->
<view class="config-group">
  <text class="config-label">处理器 (CPU)</text>
  <scroll-view class="config-scroll" scroll-x="true" enable-flex="true">
    <!-- 加载 处理器 标配 -->
    <view class="config-card {{selections.processor_code === product.processor.item_code ? 'active' : ''}}" bindtap="selectSpec" data-part-type="processor" data-item-code="{{product.processor.item_code}}">
      <text class="c-name">{{product.processor.title}}</text>
      <!-- <text class="c-price">{{product.processor.technical_description}}</text> -->
    </view>
    <!-- 加载 处理器 可选项 -->
    <block wx:for="{{upgrade_options.processor}}" wx:key="id">
      <view class="config-card {{selections.processor_code === item.item_code ? 'active' : ''}}" bindtap="selectSpec" data-part-type="processor" data-item-code="{{item.item_code}}">
        <text class="c-name">{{item.title}}</text>
        <!-- <text class="c-price">{{item.technical_description}}</text> -->
      </view>
    </block>
  </scroll-view>
</view>

