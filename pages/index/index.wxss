/**index.wxss**/
page {
  height: 100%;
  /* display: flex; */
  flex-direction: column;
  background-color: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: auto;
  /* min-height: 0; */
}

/* 轮播图 */
.gallery-swiper {
  margin: 20rpx 24rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: #cccccc;
}
.swiper-image {
  width: 100%;
  height: 350rpx;
}

/* 页面容器样式 */
.container {
  padding: 0rpx 24rpx;
  /* min-height: 100vh; */
}

/* 功能区卡片样式 */
.function-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 0rpx;
  margin-top: 20rpx;
  /* box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08); */

}

/* 功能图标网格布局 */
.function-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  /* background-color: blueviolet; */
}

/* 每个功能项样式 */
.function-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
/* 为功能项第一行添加下边距 */
.function-item-firstline
{
  /* margin-bottom: 10rpx; */
}

/* 图标容器样式 */
.icon-wrapper {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  background-color: #f0f7ff;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 6rpx;
}

/* 功能标签文字样式 */
.function-label {
  font-size: 28rpx;
  color: #333333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

/* ==================
   分类推荐板块
   ================== */

   .cat-section {
    margin: 10rpx 0 0;
    /* background-color: #fff; */
    /* background-color: thistle; */
  }
  .section-title-sm {
    font-size: 28rpx;
    color: #333333;
    font-weight: bold;
    padding-left: 20rpx;
  }
  .cat-scroll-view {
    margin-top: 20rpx;
    display: flex;
    white-space: nowrap;
    width: 100%;
    /* 高度增加以容纳详细配置列表 */
    height: 540rpx; 
    /* padding-left: 24rpx; */
    box-sizing: border-box;
    /* background-color: teal; */
  }
  
  /* 卡片主体：改为 Navigator 样式 */
  .prod-card {
    /* display: flex; */
    flex-direction: column;
    /* 宽度适当增加，防止配置文字换行过多 */
    width: 340rpx; 
    /* height: 800rpx; */
    background-color: #ffffff;
    border: 1rpx solid #e6e6e6; /* 商务风：增加细边框 */
    border-radius: 12rpx; /* 圆角改小，更显硬朗 */
    margin-left: 20rpx;
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
    box-sizing: border-box;
    margin-bottom: 15rpx;
  }
  
  /* 封面图容器 */
  .prod-cover-box {
    width: 100%;
    height: 200rpx;
    background-color: #cccccc;
    position: relative;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .prod-cover-img {
    width: 100%;
    height: 100%;
  }
  
  /* 状态标签 */
  .prod-tag {
    position: absolute;
    top: 0;
    left: 0;
    background: #0052d9; /* 品牌蓝 */
    color: #fff;
    font-size: 20rpx;
    padding: 4rpx 12rpx;
    border-bottom-right-radius: 12rpx;
  }
  
  /* 内容容器 */
  .prod-content {
    /* flex: 1; */
    padding: 20rpx;
    display: flex;
    flex-direction: column;
    /* background-color: wheat; */
  }
  
  .prod-title {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 12rpx;
  }
  
  .prod-divider {
    height: 1rpx;
    background-color: #eeeeee;
    width: 100%;
    margin-bottom: 12rpx;
  }
  
  /* 配置详情列表 (核心修改) */
  .prod-spec-list {
    /* flex: 1; 撑开中间区域 */
    display: flex;
    flex-direction: column;
    gap: 8rpx; /* 行间距 */
  }
  
  .spec-item {
    display: flex;
    /* align-items: center; 垂直居中 */
    font-size: 20rpx;
    line-height: 1.2;
  }
  
  .spec-label {
    color: #999999;
    width: 56rpx; /* 固定宽度实现对齐 */
    flex-shrink: 0;
    font-weight: 400;
  }
  
  .spec-val {
    color: #555555;
    /* flex: 1; */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; /* 英文数字字体优化 */
  }
  
  /* 底部价格行 */
  .prod-bottom-row {
    display: flex;
    /* justify-content: space-between; */
    /* align-items: flex-end; */
    margin-top: 16rpx;
    padding-top: 12rpx;
    border-top: 1rpx dashed #eee; /* 虚线分隔 */
    /* background-color: steelblue; */
  }
  
  .price-group {
    color: #e34d59;
    /* display: flex; */
    /* align-items: baseline; */
  }
  
  .p-symbol {
    font-size: 22rpx;
    font-weight: bold;
  }
  
  .p-num {
    font-size: 30rpx;
    font-weight: bold;
    margin: 0 2rpx;
  }
  
  .p-unit {
    font-size: 20rpx;
    color: #999;
  }
  
  /* 行动引导文字 */
  .action-text {
    font-size: 20rpx;
    color: #0052d9;
    background: #f0f7ff;
    padding: 4rpx 12rpx;
    border-radius: 4rpx;
  }