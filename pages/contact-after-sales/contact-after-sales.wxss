/* contact.wxss */
/* 复用部分 - 保持风格统一 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, sans-serif;
}

.container { padding-bottom: 60rpx; }

.banner-box {
  position: relative;
  width: 100%;
  height: 300rpx; /* 比关于我们稍矮一点 */
  background-color: #2c3e50;
}
.banner-img { width: 100%; height: 100%; opacity: 0.6; }
.banner-text {
  position: absolute; bottom: 0; left: 0; width: 100%; padding: 30rpx;
  color: #fff; box-sizing: border-box;
}
.banner-title { font-size: 36rpx; font-weight: bold; display: block; }
.banner-sub { font-size: 24rpx; opacity: 0.9; margin-top: 8rpx; display: block;}

.section-card {
  background-color: #fff; margin: 24rpx; padding: 32rpx;
  border-radius: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.section-title {
  font-size: 30rpx; font-weight: 600; color: #333;
  margin-bottom: 24rpx; padding-left: 16rpx; border-left: 8rpx solid #0052d9;
}
.highlight { color: #0052d9; font-weight: bold; }

/* --- 差异化样式 --- */

/* 团队徽章 */
.team-badge {
  background: #eef2ff; color: #0052d9; font-size: 24rpx;
  padding: 12rpx 20rpx; border-radius: 8rpx; text-align: center; margin-bottom: 30rpx; font-weight: 500;
}

/* 联系列表 */
.contact-item {
  display: flex; align-items: center; padding: 24rpx 0;
  border-bottom: 1px solid #f0f0f0;
}
.contact-item:last-child { border-bottom: none; }
/* 按钮重置样式 */
.btn-reset {
  background: #fff; text-align: left; line-height: normal;
  margin: 0; width: 100%;
}
.btn-reset::after { border: none; }

.c-icon { width: 64rpx; height: 64rpx; margin-right: 24rpx; }
.c-info { flex: 1; display: flex; flex-direction: column; }
.c-title { font-size: 30rpx; color: #333; font-weight: 500; }
.c-desc { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.c-action {
  font-size: 24rpx; color: #0052d9; border: 1px solid #0052d9;
  padding: 6rpx 20rpx; border-radius: 24rpx;
}

/* 服务策略 */
.policy-item { margin-bottom: 24rpx; }
.policy-header { display: flex; justify-content: space-between; margin-bottom: 10rpx; }
.policy-tag {
  font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 4rpx; color: #fff;
}
.policy-tag.blue { background-color: #0052d9; }
.policy-tag.gray { background-color: #faad14; } /* 橙色区分 */
.policy-area { font-size: 24rpx; color: #999; }
.policy-content { font-size: 26rpx; color: #555; line-height: 1.5; background: #f9f9f9; padding: 16rpx; border-radius: 8rpx;}

/* FAQ */
.faq-item { margin-bottom: 20rpx; }
.faq-q { display: block; font-size: 26rpx; color: #333; font-weight: 500; margin-bottom: 8rpx; }
.faq-a { display: block; font-size: 24rpx; color: #666; line-height: 1.4; padding-left: 20rpx; }