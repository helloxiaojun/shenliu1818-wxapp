.config-list {
  padding: 10rpx 0;
}
.config-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.config-item:last-child {
  border-bottom: none;
}
.label {
  font-size: 26rpx;
  color: #666;
}
.value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}