/* process.wxss */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, sans-serif;
  padding-bottom: 120rpx; /* 为底部按钮留空间 */
}

/* Banner (保持统一) */
.banner-box {
  position: relative; width: 100%; height: 300rpx; background-color: #2c3e50;
}
.banner-img { width: 100%; height: 100%; opacity: 0.6; }
.banner-text {
  position: absolute; bottom: 0; left: 0; width: 100%; padding: 30rpx;
  color: #fff; box-sizing: border-box;
}
.banner-title { font-size: 36rpx; font-weight: bold; display: block; }
.banner-sub { font-size: 24rpx; opacity: 0.9; margin-top: 8rpx; display: block;}

/* 卡片容器 */
.section-card {
  background-color: #fff; margin: 24rpx; padding: 32rpx;
  border-radius: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.section-title {
  font-size: 30rpx; font-weight: 600; color: #333;
  margin-bottom: 30rpx; padding-left: 16rpx; border-left: 8rpx solid #0052d9;
}

/* --- 资质准备板块 --- */
.auth-tabs { display: flex; justify-content: space-between; position: relative; }
.auth-box { width: 46%; }
.divider-v {
  width: 1px; background-color: #eee; position: absolute;
  left: 50%; top: 10rpx; bottom: 10rpx;
}

.auth-header {
  display: flex; align-items: center; margin-bottom: 20rpx; justify-content: center;
}
.auth-icon { width: 40rpx; height: 40rpx; margin-right: 10rpx; }
.auth-header text { font-weight: bold; font-size: 28rpx; color: #333; }

.list-item { font-size: 24rpx; color: #666; margin-bottom: 12rpx; line-height: 1.4; }
.list-item.highlight { color: #d95100; font-weight: 500; } /* 强调芝麻信用 */

.tips { font-size: 22rpx; color: #999; margin-top: 20rpx; text-align: center; }

/* --- 垂直时间轴样式 --- */
.step-item { display: flex; min-height: 140rpx; }

.step-left {
  width: 60rpx; display: flex; flex-direction: column; align-items: center; margin-right: 20rpx;
}
.step-circle {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background-color: #eee; color: #999;
  font-size: 24rpx; display: flex; align-items: center; justify-content: center;
  font-weight: bold; z-index: 1;
}
.step-circle.active { background-color: #0052d9; color: #fff; }

.step-line {
  width: 2px; flex: 1; background-color: #eee; margin-top: -4rpx; margin-bottom: -4rpx;
}

.step-right { flex: 1; padding-bottom: 40rpx; }
.step-title { font-size: 30rpx; font-weight: 600; color: #333; display: block; margin-bottom: 8rpx; }
.step-desc { font-size: 26rpx; color: #666; line-height: 1.5; }

/* 底部固定按钮 */
.footer-action {
  position: fixed; bottom: 0; left: 0; width: 100%;
  padding: 20rpx 40rpx; background: #fff; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
}
.btn-primary {
  background-color: #0052d9; color: #fff; border-radius: 40rpx;
  font-size: 30rpx; font-weight: 500;
}