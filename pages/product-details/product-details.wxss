/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f7fa;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  /* padding-top: 20rpx; */
}

/* 轮播图 */
.gallery-swiper {
  margin: 20rpx 24rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: #cccccc;
}

.swiper-image {
  width: 100%;
  height: 350rpx;
}

/* 通用卡片 */
.section-card {
  background-color: #FFFFFF;
  margin: 20rpx 24rpx 0;
  padding: 30rpx;
  border-radius: 16rpx;
  /* box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); */
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #0052d9;
}

/* 头部信息 */
.header-card {
  padding-top: 40rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 16rpx;
}

.stock-tag {
  font-size: 22rpx;
  color: #0052d9;
  background-color: #eef2ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.product-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.product-subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}

/* 销售引导条 */
.sales-contact-bar {
  background: linear-gradient(90deg, #f0f7ff 0%, #e6f0ff 100%);
  border: 1px solid #dbeafe;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sales-info {
  display: flex;
  align-items: center;
}

.sales-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.sales-text {
  display: flex;
  flex-direction: column;
}

.s-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #0052d9;
  margin-bottom: 4rpx;
}

.s-desc {
  font-size: 22rpx;
  color: #666;
}

/* 服务保障 */
.service-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  /* margin-bottom: 10rpx; */
}

.tag-item icon {
  color: #0052d9;
  margin-right: 8rpx;
}

.tag-item text {
  font-size: 24rpx;
  color: #555555;
}

/* 增值服务 */
.ad-section {
  margin: 30rpx 0 0;
  padding: 0;
}
.section-title-sm {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  padding-left: 24rpx;
}
.ad-scroll-view {
  margin-top: 24rpx;
  /* padding-bottom: 5rpx; */
  display: flex;
  white-space: nowrap;
  width: 100%;
  height: 295rpx;
  /* box-sizing: border-box; */
}
.ad-card-square {
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  width: 280rpx;
  height: 280rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}
.ad-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.blue-bg {
  background: #eef2ff;
  /* color: #0052d9; */
}
.green-bg {
  background: #e6fffa;
  color: #00a870;
}
.ad-content-box {
  display: flex;
  flex-direction: column;
  margin-top: 16rpx;
  flex: 1;
}
.ad-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  white-space: normal;
}
.ad-desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
  white-space: normal;
}
.ad-action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}
.ad-link-text {
  font-size: 22rpx;
  color: #0052d9;
  font-weight: 500;
}
.arrow {
  font-size: 24rpx;
  color: #cccccc;
}

/* 底栏 */
.footer-placeholder {
  margin-top: 20rpx;
  height: 110rpx;
}
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 110rpx;
  background-color: #ffffff;
  /* background-color: brown; */
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  z-index: 100;
}
.footer-icons {
  display: flex;
  margin-right: 30rpx;
}
.icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  background: transparent;
  padding: 0;
  margin: 0;
  line-height: 1.2;
}
.icon-btn::after {
  border: none;
}
.bar-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}
.icon-btn text {
  font-size: 20rpx;
  color: #666666;
}
.footer-buttons {
  flex: 1;
  display: flex;
  justify-content: space-between;
  /* background-color: aqua; */
}
/* 价格标识 */
.price-box {
  display: flex;
  color: #e34d59;
  font-weight: bold;
  align-items: flex-end;
  /* background-color: blueviolet; */
}

.currency {
  font-size: 28rpx;
}

.amount {
  font-size: 48rpx;
  margin: 0 4rpx;
}

.unit {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}
/* 加入清单按钮 */
.action-btn {
  /* flex:1; */
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}
.cart-btn {
  /* margin-left: auto; */
  background-color: #eef2ff;
  color: #0052d9;
  border: 2rpx solid #dbeafe;
}
